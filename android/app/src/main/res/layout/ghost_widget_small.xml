<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0a0a08">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/gs_header"
        android:layout_width="match_parent"
        android:layout_height="26dp"
        android:background="#111109"
        android:gravity="center_vertical"
        android:paddingLeft="10dp"
        android:paddingRight="6dp"
        android:orientation="horizontal">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GL"
            android:textColor="#f5a623"
            android:textSize="10sp"
            android:textStyle="bold"
            android:paddingRight="6dp"/>
        <TextView
            android:id="@+id/gs_price"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=""
            android:textColor="#a89060"
            android:textSize="8sp"
            android:gravity="center_horizontal"
            android:maxLines="1"
            android:ellipsize="end"/>
        <TextView
            android:id="@+id/gs_refresh"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="↻"
            android:textColor="#f5a623"
            android:textSize="13sp"
            android:paddingLeft="6dp"
            android:paddingRight="2dp"/>
    </LinearLayout>

    <!-- Story 0 -->
    <LinearLayout
        android:id="@+id/gs_row_0"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#0a0a08"
        android:gravity="center_vertical"
        android:paddingLeft="10dp"
        android:paddingRight="10dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:orientation="horizontal">
        <TextView android:id="@+id/gs_num_0" android:layout_width="16dp" android:layout_height="wrap_content" android:textColor="#f5a623" android:textSize="9sp" android:textStyle="bold"/>
        <TextView android:id="@+id/gs_title_0" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textColor="#d4c08a" android:textSize="9sp" android:maxLines="2" android:ellipsize="end"/>
        <TextView android:id="@+id/gs_time_0" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#3a3a30" android:textSize="8sp" android:paddingLeft="6dp"/>
    </LinearLayout>

    <TextView android:layout_width="match_parent" android:layout_height="1dp" android:background="#1a1a14" android:text=""/>

    <!-- Story 1 -->
    <LinearLayout
        android:id="@+id/gs_row_1"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#0d0d0a"
        android:gravity="center_vertical"
        android:paddingLeft="10dp"
        android:paddingRight="10dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:orientation="horizontal">
        <TextView android:id="@+id/gs_num_1" android:layout_width="16dp" android:layout_height="wrap_content" android:textColor="#f5a623" android:textSize="9sp" android:textStyle="bold"/>
        <TextView android:id="@+id/gs_title_1" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textColor="#d4c08a" android:textSize="9sp" android:maxLines="2" android:ellipsize="end"/>
        <TextView android:id="@+id/gs_time_1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#3a3a30" android:textSize="8sp" android:paddingLeft="6dp"/>
    </LinearLayout>

    <TextView android:layout_width="match_parent" android:layout_height="1dp" android:background="#1a1a14" android:text=""/>

    <!-- Story 2 -->
    <LinearLayout
        android:id="@+id/gs_row_2"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#0a0a08"
        android:gravity="center_vertical"
        android:paddingLeft="10dp"
        android:paddingRight="10dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:orientation="horizontal">
        <TextView android:id="@+id/gs_num_2" android:layout_width="16dp" android:layout_height="wrap_content" android:textColor="#f5a623" android:textSize="9sp" android:textStyle="bold"/>
        <TextView android:id="@+id/gs_title_2" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textColor="#d4c08a" android:textSize="9sp" android:maxLines="2" android:ellipsize="end"/>
        <TextView android:id="@+id/gs_time_2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#3a3a30" android:textSize="8sp" android:paddingLeft="6dp"/>
    </LinearLayout>

</LinearLayout>
