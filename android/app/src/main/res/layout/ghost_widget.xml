<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0a0a08">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/gl_header"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:background="#111109"
        android:gravity="center_vertical"
        android:paddingLeft="8dp"
        android:paddingRight="6dp"
        android:orientation="horizontal">
        <ImageView
            android:id="@+id/gl_logo_icon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@mipmap/ic_launcher"
            android:scaleType="fitCenter"
            android:contentDescription="@string/app_name"/>
        <TextView
            android:id="@+id/gl_logo_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GhostLetter"
            android:textColor="#f5a623"
            android:textSize="10sp"
            android:textStyle="bold"
            android:paddingLeft="6dp"
            android:paddingRight="8dp"/>
        <TextView
            android:id="@+id/gl_price"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=""
            android:textColor="#a89060"
            android:textSize="8sp"
            android:gravity="center_horizontal"
            android:maxLines="1"
            android:ellipsize="end"/>
        <TextView
            android:id="@+id/gl_refresh"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="↻"
            android:textColor="#f5a623"
            android:textSize="20sp"
            android:paddingLeft="6dp"
            android:paddingRight="2dp"/>
    </LinearLayout>

    <!-- Row 0 -->
    <LinearLayout
        android:id="@+id/gl_row_0"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#0a0a08"
        android:gravity="center_vertical"
        android:paddingLeft="10dp"
        android:paddingRight="10dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:orientation="horizontal"
        android:visibility="visible">
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
            <TextView android:id="@+id/gl_src_0" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#a89060" android:textSize="9sp" android:textStyle="bold" android:maxLines="1" android:ellipsize="end"/>
            <TextView android:id="@+id/gl_title_0" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#d4c08a" android:textSize="11sp" android:maxLines="2" android:ellipsize="end"/>
        </LinearLayout>
        <ImageView android:id="@+id/gl_thumb_0" android:layout_width="44dp" android:layout_height="44dp" android:scaleType="centerCrop" android:visibility="gone" android:src="@android:color/transparent" android:contentDescription="@string/app_name"/>
    </LinearLayout>
    <TextView android:id="@+id/gl_div_0" android:layout_width="match_parent" android:layout_height="1dp" android:background="#1a1a14" android:text=""/>

