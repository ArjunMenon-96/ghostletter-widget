<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0a0a08">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/gl_header"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:background="#111109"
        android:gravity="center_vertical"
        android:paddingLeft="10dp"
        android:paddingRight="6dp"
        android:orientation="horizontal">
        <TextView
            android:id="@+id/gl_logo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GL"
            android:textColor="#f5a623"
            android:textSize="11sp"
            android:textStyle="bold"
            android:paddingRight="8dp"/>
        <TextView
            android:id="@+id/gl_price"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=""
            android:textColor="#a89060"
            android:textSize="8sp"
            android:gravity="center_horizontal"
            android:singleLine="true"/>
        <TextView
            android:id="@+id/gl_refresh"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="↻"
            android:textColor="#f5a623"
            android:textSize="14sp"
            android:paddingLeft="6dp"
            android:paddingRight="2dp"/>
    </LinearLayout>

    <!-- Story 0 -->
    <LinearLayout
        android:id="@+id/gl_row_0"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#0a0a08"
        android:gravity="center_vertical"
        android:paddingLeft="10dp"
        android:paddingRight="10dp"
        android:paddingTop="3dp"
        android:paddingBottom="3dp"
        android:orientation="horizontal">
        <TextView android:id="@+id/gl_num_0" android:layout_width="18dp" android:layout_height="wrap_content" android:textColor="#f5a623" android:textSize="9sp" android:textStyle="bold"/>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <TextView android:id="@+id/gl_src_0" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#a89060" android:textSize="8sp" android:textStyle="bold"/>
                <TextView android:id="@+id/gl_time_0" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textColor="#3a3a30" android:textSize="8sp" android:gravity="end"/>
            </LinearLayout>
            <TextView android:id="@+id/gl_title_0" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#d4c08a" android:textSize="10sp" android:maxLines="2"/>
        </LinearLayout>
    </LinearLayout>

    <TextView android:layout_width="match_parent" android:layout_height="1dp" android:background="#1a1a14" android:text=""/>

    <!-- Story 1 -->
    <LinearLayout
        android:id="@+id/gl_row_1"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#0d0d0a"
        android:gravity="center_vertical"
        android:paddingLeft="10dp"
        android:paddingRight="10dp"
        android:paddingTop="3dp"
        android:paddingBottom="3dp"
        android:orientation="horizontal">
        <TextView android:id="@+id/gl_num_1" android:layout_width="18dp" android:layout_height="wrap_content" android:textColor="#f5a623" android:textSize="9sp" android:textStyle="bold"/>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <TextView android:id="@+id/gl_src_1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#a89060" android:textSize="8sp" android:textStyle="bold"/>
                <TextView android:id="@+id/gl_time_1" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textColor="#3a3a30" android:textSize="8sp" android:gravity="end"/>
            </LinearLayout>
            <TextView android:id="@+id/gl_title_1" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#d4c08a" android:textSize="10sp" android:maxLines="2"/>
        </LinearLayout>
    </LinearLayout>

    <TextView android:layout_width="match_parent" android:layout_height="1dp" android:background="#1a1a14" android:text=""/>

    <!-- Story 2 -->
    <LinearLayout
        android:id="@+id/gl_row_2"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#0a0a08"
        android:gravity="center_vertical"
        android:paddingLeft="10dp"
        android:paddingRight="10dp"
        android:paddingTop="3dp"
        android:paddingBottom="3dp"
        android:orientation="horizontal">
        <TextView android:id="@+id/gl_num_2" android:layout_width="18dp" android:layout_height="wrap_content" android:textColor="#f5a623" android:textSize="9sp" android:textStyle="bold"/>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <TextView android:id="@+id/gl_src_2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#a89060" android:textSize="8sp" android:textStyle="bold"/>
                <TextView android:id="@+id/gl_time_2" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textColor="#3a3a30" android:textSize="8sp" android:gravity="end"/>
            </LinearLayout>
            <TextView android:id="@+id/gl_title_2" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#d4c08a" android:textSize="10sp" android:maxLines="2"/>
        </LinearLayout>
    </LinearLayout>

    <TextView android:layout_width="match_parent" android:layout_height="1dp" android:background="#1a1a14" android:text=""/>

    <!-- Story 3 -->
    <LinearLayout
        android:id="@+id/gl_row_3"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#0d0d0a"
        android:gravity="center_vertical"
        android:paddingLeft="10dp"
        android:paddingRight="10dp"
        android:paddingTop="3dp"
        android:paddingBottom="3dp"
        android:orientation="horizontal">
        <TextView android:id="@+id/gl_num_3" android:layout_width="18dp" android:layout_height="wrap_content" android:textColor="#f5a623" android:textSize="9sp" android:textStyle="bold"/>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <TextView android:id="@+id/gl_src_3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#a89060" android:textSize="8sp" android:textStyle="bold"/>
                <TextView android:id="@+id/gl_time_3" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textColor="#3a3a30" android:textSize="8sp" android:gravity="end"/>
            </LinearLayout>
            <TextView android:id="@+id/gl_title_3" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#d4c08a" android:textSize="10sp" android:maxLines="2"/>
        </LinearLayout>
    </LinearLayout>

    <TextView android:layout_width="match_parent" android:layout_height="1dp" android:background="#1a1a14" android:text=""/>

    <!-- Story 4 -->
    <LinearLayout
        android:id="@+id/gl_row_4"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#0a0a08"
        android:gravity="center_vertical"
        android:paddingLeft="10dp"
        android:paddingRight="10dp"
        android:paddingTop="3dp"
        android:paddingBottom="3dp"
        android:orientation="horizontal">
        <TextView android:id="@+id/gl_num_4" android:layout_width="18dp" android:layout_height="wrap_content" android:textColor="#f5a623" android:textSize="9sp" android:textStyle="bold"/>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <TextView android:id="@+id/gl_src_4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#a89060" android:textSize="8sp" android:textStyle="bold"/>
                <TextView android:id="@+id/gl_time_4" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textColor="#3a3a30" android:textSize="8sp" android:gravity="end"/>
            </LinearLayout>
            <TextView android:id="@+id/gl_title_4" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#d4c08a" android:textSize="10sp" android:maxLines="2"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Footer -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="16dp"
        android:background="#111109"
        android:gravity="center_vertical"
        android:paddingLeft="10dp"
        android:paddingRight="10dp"
        android:orientation="horizontal">
        <TextView
            android:id="@+id/gl_footer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ghostletter.online"
            android:textColor="#2a2a20"
            android:textSize="7sp"
            android:gravity="end"/>
    </LinearLayout>

</LinearLayout>
