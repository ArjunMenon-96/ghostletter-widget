{
  "expo": {
    "name": "GhostLetter",
    "slug": "ghostletter-widget",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#09090b"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ghostletter.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#09090b"
      },
      "package": "com.ghostletter.app",
      "versionCode": 4
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "GhostWidget",
              "label": "GhostLetter Widget",
              "minWidth": "180dp",
              "minHeight": "110dp",
              "minResizeWidth": "180dp",
              "minResizeHeight": "80dp",
              "maxResizeWidth": "500dp",
              "maxResizeHeight": "400dp",
              "targetCellWidth": 4,
              "targetCellHeight": 2,
              "resizeMode": "horizontal|vertical",
              "description": "Latest crypto & DeFi headlines",
              "previewImage": "./assets/widget-preview.png",
              "updatePeriodMillis": 1800000
            }
          ]
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "04a76209-8492-42cd-ac3f-d49dbc335467"
      }
    }
  }
}
